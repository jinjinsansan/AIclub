# OPEN CLAW マスター管理システム 環境変数テンプレート
# .env にコピーして実際の値を設定してください

# === 基本設定 ===
NODE_ENV=development
PORT=3001
MASTER_ID=master_001

# === Supabase設定 ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# === MINARA API設定 ===
MINARA_API_ENDPOINT=https://api.minara.ai/v1
MINARA_API_KEY=minara_api_key_here
MASTER_WALLET_ADDRESS=0x...master_wallet_address
OPERATOR_WALLET_ADDRESS=0x...operator_wallet_address

# === 支払い設定 ===
INITIAL_FEE_USD=700
OPERATOR_SHARE_USD=400
REFERRAL_L1_USD=200
REFERRAL_L2_USD=50
REFERRAL_L3_USD=50
MONTHLY_REWARD_DAY=31
REMINDER_DAYS_BEFORE=5

# === LINE通知設定 ===
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_GROUP_ID=your_line_group_id
LINE_NOTIFY_TOKEN=your_line_notify_token

# === セキュリティ設定 ===
WEBHOOK_SECRET=your_webhook_secret_here
MASTER_API_KEY=your_master_api_key_here
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# === ログ設定 ===
LOG_LEVEL=info
LOG_DIRECTORY=./logs

# === その他設定 ===
HEARTBEAT_CHECK_INTERVAL_SEC=60