# OPEN CLAW システム 環境変数テンプレート
# 本番環境では実際の値に置き換えてください

# Supabase 設定
NEXT_PUBLIC_SUPABASE_URL=https://[project-id].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# MINARA AI 設定
MINARA_API_KEY=minara_...
MINARA_WEBHOOK_SECRET=whsec_...
MASTER_WALLET_ADDRESS=0x...
OPERATOR_WALLET_ADDRESS=0x...

# 支払い設定
INITIAL_FEE_USD=700
OPERATOR_SHARE_USD=400
REFERRAL_L1_USD=200
REFERRAL_L2_USD=50
REFERRAL_L3_USD=50

# LINE 通知設定
LINE_CHANNEL_ACCESS_TOKEN=...
LINE_GROUP_ID=...
LINE_NOTIFY_TOKEN=...

# マスター管理CLAW設定
MASTER_API_KEY=master_...
MASTER_ID=master_001

# セキュリティ
JWT_SECRET=...
WEBHOOK_SECRET=...

# Next.js 設定
NEXTAUTH_URL=https://openclaw.com
NEXTAUTH_SECRET=...

# 外部サービス
RESEND_API_KEY=...  # メール送信
VERCEL_URL=...      # デプロイURL

# Phase 5: OpenClaw Gateway設定
GATEWAY_PORT=18789
GATEWAY_HOST=0.0.0.0
GATEWAY_WSS_URL=wss://gateway.openclaw.community:18789
RATE_LIMIT_MESSAGES_PER_MINUTE=10
RATE_LIMIT_CONNECTIONS_PER_IP=5

# 開発環境
NODE_ENV=development