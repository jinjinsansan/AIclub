# OPEN CLAW メンバーCLAWテンプレート 環境変数
# .env にコピーして実際の値を設定してください

# === 基本設定 ===
NODE_ENV=development
MEMBER_ID=your_member_id_here

# === Supabase設定 (ゲートウェイ接続用) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# === MINARA API設定 ===
MINARA_API_ENDPOINT=https://api.minara.ai/v1
MINARA_API_KEY=your_minara_api_key_here
WALLET_ADDRESS=0x...your_wallet_address

# === トレード設定 ===
AUTO_EXECUTE=true
MAX_POSITION_SIZE=10%
STOP_LOSS_PCT=2.0
DAILY_TRADE_LIMIT=5

# === ログ設定 ===
LOG_LEVEL=info
